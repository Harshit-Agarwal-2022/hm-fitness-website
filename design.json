  "cursor_instructions": {
    "framework": "Plain HTML + CSS (or React if preferred)",
    "notes": [
      "Use the colors object as CSS custom properties (--bg-darkest, --accent-primary, etc.).",
      "Each section in the sections array maps to a <section> element with its id as the HTML id attribute.",
      "All buttons use the border-radius:999px pill shape from components.",
      "The sticky jump_nav should highlight the active anchor on scroll.",
      "Staff cards in the team section should show avatar, name, role badge, and a short bio.",
      "Amenity items in the amenities section should be grouped by category with colored headings.",
      "Images can be loaded from the src URLs provided — they are publicly accessible.",
      "The map in location_info can use a static Google Maps embed iframe.",
      "Keep the page responsive — stack columns to single column on mobile."
    ]
  }
